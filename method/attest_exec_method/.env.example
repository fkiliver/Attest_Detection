# Attest LLM backend configuration. Copy this file to `.env` and fill in
# your key. `.env` is git-ignored and must never be committed.

# Required: API key for the OpenAI-compatible LLM endpoint.
LLM_API_KEY=your-api-key-here

# Optional overrides (defaults shown):
# LLM_BASE_URL=https://llm-provider.example/v1
# LLM_MODEL=configured-llm
